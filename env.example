# Configuração de portas do servidor dual HTTP/HTTPS
# Copie este arquivo para .env.local e ajuste se necessário

# Porta do servidor HTTP (páginas públicas: / e /politica-de-seguranca)
PORT_HTTP=9002

# Porta do servidor HTTPS (dados sensíveis: /auth /dashboard /api)
PORT_HTTPS=9443

# URL pública da API backend (não altere em produção sem certificado válido)
# NEXT_PUBLIC_BASEURL=http://localhost:3333/
